# Environment variables for Docker Compose
# Copy this file to .env and fill in your values

# ─── Database Configuration ─────────────────────────────────────────────
POSTGRES_USER=cfuser
POSTGRES_PASSWORD=cfpassword
POSTGRES_DB=cfcompare

# ─── Codeforces API Credentials ─────────────────────────────────────────
# Get your API key and secret from: https://codeforces.com/settings/api
API_KEY=
API_SECRET=

# ─── Cache TTL (seconds) ────────────────────────────────────────────────
# Comparisons within this window are served from DB cache
CACHE_TTL_SECONDS=600

# ─── LLM Integration (Optional) ─────────────────────────────────────────
# Option A: OpenAI-compatible endpoint
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-3.5-turbo

# Option B: Ollama (local self-hosted)
# LLM_API_URL=http://ollama:11434/api/generate
# LLM_MODEL=llama3

# If neither is set, the app uses a built-in rule-based insight generator.

# ─── JWT Authentication ─────────────────────────────────────────────────
# Secret key for signing JWT tokens. CHANGE THIS in production!
JWT_SECRET=dev-secret-change-me-in-production
